# .gcloudignore file
# Include everything from .gitignore except Firebase config files

# Visual Studio
.vs/
obj/
bin/
packages/
out/

# Environment files - NEVER commit these
.env
.env.local
.env.development
.env.staging
.env.production
setup-env.sh

# Published configuration with secrets
publish/appsettings.json
appsettings.json.backup

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
**/packages/*
!**/packages/build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Firebase - COMMENTED OUT to allow Firebase config in build context
# *firebase.json

# Explicitly include Firebase config files needed for build
!lifepadi-24bfe-firebase.json
!lifepadi-17e8c-firebase.json
