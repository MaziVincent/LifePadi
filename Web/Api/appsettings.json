{
	"ConnectionStrings": {
		"LifePadiDBConnection": "Server=${DB_SERVER};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USERNAME};Password=${DB_PASSWORD};"
	},
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"Jwt": {
		"Key": "${JWT_KEY}"
	},
	"Cloudinary": {
		"Cloud_Name": "${CLOUDINARY_CLOUD_NAME}",
		"Api_Key": "${CLOUDINARY_API_KEY}",
		"Api_Secret": "${CLOUDINARY_API_SECRET}"
	},
	"Base_Url": {
		"Local": "${API_LOCAL_URL}",
		"Remote": "${API_REMOTE_URL}",
		"Remote_GCP": "${API_REMOTE_GCP_URL}",
		"Frontend_local": "${FRONTEND_LOCAL_URL}",
		"Frontend_remote": "${FRONTEND_REMOTE_URL}",
		"Frontend_Remote_SubDomain": "${FRONTEND_REMOTE_SUBDOMAIN_URL}"
	},

	"FW_Payment": {
		"Secret_key": "${FW_PAYMENT_SECRET_KEY}"
	},
	"Google_Maps": {
		"Api_Key": "${GOOGLE_MAPS_API_KEY}"
	},
	"Termii": {
		"Api_Key": "${TERMII_API_KEY}",
		"Sender_Id": "${TERMII_SENDER_ID}",
		"Base_Url": "https://v3.api.termii.com",
		"SendOtp_Url": "https://v3.api.termii.com/api/sms/otp/send",
		"VerifyOtp_Url": "https://v3.api.termii.com/api/sms/otp/verify"
	},
	"SMTPConfig": {
		"Server": "${SMTP_SERVER}",
		"Port": "${SMTP_PORT}",
		"Username": "${SMTP_USERNAME}",
		"Password": "${SMTP_PASSWORD}",
		"Sender": "${SMTP_SENDER}",
		"Sender_Email": "${SMTP_SENDER_EMAIL}",
		"EnableSsl": "${SMTP_ENABLE_SSL}"
	},
	
	"Logo": {
		"Dark": "https://res.cloudinary.com/dbxapeqzu/image/upload/v1725192449/LifePadi/logo/Logo_name_tagline_dark_zpvmfe_owcav8.png",
		"Light": "https://res.cloudinary.com/dbxapeqzu/image/upload/v1725192449/LifePadi/logo/Logo_name_tagline_light_chiec1_rh825p.png"
	},
	"Bani": {
		"Public_Key": "${BANI_PUBLIC_KEY}",
		"Private_Key": "${BANI_PRIVATE_KEY}",
		"Account_Tribe_Ref": "${BANI_ACCOUNT_TRIBE_REF}",
		"Access_Token": "${BANI_ACCESS_TOKEN}",
		"Stage_Base_Url": "https://stage.getbani.com/api/v1",
		"Live_Base_Url": "https://live.getbani.com/api/v1",
		"Merchant_Key": "${BANI_MERCHANT_KEY}"
	},
	"Paystack": {
		"Secret_Key": "${PAYSTACK_SECRET_KEY}",
		"Public_Key": "${PAYSTACK_PUBLIC_KEY}",
		"Initialize_Payment_Url": "https://api.paystack.co/transaction/initialize",
		"Verify_Payment_Url": "https://api.paystack.co/transaction/verify",
		"Test_Key": "${PAYSTACK_TEST_KEY}"
	},
	"Distance": {
		"Price_Per_Kilometer": "${PRICE_PER_KILOMETER}"
	}
}
