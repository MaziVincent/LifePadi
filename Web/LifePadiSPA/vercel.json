{ "rewrites": [
	{
		"source": "/.well-known/(.*)",
        "headers": [
            {
                "key":"Content-Type",
                "value":"application/json"
            }
        ],
		"destination": "/.well-known/$1"

	},
	{
		"source": "app.lifepadi.com",
		"destination": "/index.html?subdomain=app"
	},
	{ "source": "/(.*)", "destination": "/index.html" }
] }
